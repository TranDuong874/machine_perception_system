# Default server runtime config for local development.
MPS_SERVER_BIND_HOST=127.0.0.1
MPS_SERVER_PORT=19100
MPS_SERVER_GRPC_WORKERS=8
MPS_SERVER_INGRESS_QUEUE_SIZE=256
MPS_SERVER_ENQUEUE_TIMEOUT_S=0.02
MPS_SERVER_LOG_EVERY_N=20
MPS_SERVER_FRAME_STORE_MAX_PACKETS=512
MPS_SERVER_DEPTH_TASK_QUEUE_SIZE=16
MPS_SERVER_MEMORY_TASK_QUEUE_SIZE=32
MPS_SERVER_DEPTH_SELECT_EVERY_N_FRAMES=4
MPS_SERVER_DEPTH_SELECT_TRANSLATION_M=0.15
MPS_SERVER_DEPTH_SELECT_ROTATION_DEG=8.0
MPS_SERVER_MEMORY_SELECT_EVERY_N_FRAMES=8
MPS_SERVER_MEMORY_SELECT_TRANSLATION_M=0.25
MPS_SERVER_MEMORY_SELECT_ROTATION_DEG=12.0
MPS_SERVER_MEMORY_SCHEDULE_ON_DETECTION_CHANGE=1
MPS_SERVER_ENABLE_GUI=1
MPS_SERVER_PREVIEW_DELAY_MS=1
MPS_SERVER_HEADLESS_PREVIEW_PATH=/tmp/mps_server_preview.jpg
MPS_SERVER_ENABLE_DEPTH=1
MPS_SERVER_DEPTH_MODEL_ID=depth-anything/DA3-BASE
MPS_SERVER_DEPTH_DEVICE=cuda
MPS_SERVER_DEPTH_PROCESS_RES=504
MPS_SERVER_ENABLE_RECTIFICATION=1
MPS_SERVER_CAMERA_CALIBRATION_FILE=dataset/dataset-corridor1_512_16/dso/camchain.yaml
MPS_SERVER_CAMERA_KEY=cam0
MPS_SERVER_RECTIFICATION_BALANCE=0.0
MPS_SERVER_ENABLE_MAPPING=1
MPS_SERVER_MAP_ID=main
MPS_SERVER_MAP_RESOLUTION_M=0.10
MPS_SERVER_MAP_WIDTH=400
MPS_SERVER_MAP_HEIGHT=400
MPS_SERVER_MAP_POINT_STRIDE=8
MPS_SERVER_MAP_MAX_POINTS_PER_FRAME=2500
MPS_SERVER_MAP_MIN_DEPTH_M=0.30
MPS_SERVER_MAP_MAX_DEPTH_M=8.00
MPS_SERVER_MAP_CONFIDENCE_PERCENTILE=55.0
MPS_SERVER_MAP_MIN_CONFIDENCE=1.0
MPS_SERVER_MAP_MIN_HEIGHT_OFFSET_M=-1.5
MPS_SERVER_MAP_MAX_HEIGHT_OFFSET_M=0.6
MPS_SERVER_MAP_FREE_SPACE_DECREMENT=0.12
MPS_SERVER_MAP_OCCUPIED_INCREMENT=0.65
MPS_SERVER_STORAGE_DB_PATH=/tmp/mps_server_runtime.sqlite3
MPS_SERVER_STORAGE_ARTIFACT_DIR=/tmp/mps_server_artifacts
MPS_SERVER_SAVE_DEBUG_ARTIFACTS=0
MPS_SERVER_SAVE_MAP_EVERY_N_UPDATES=5
MPS_SERVER_ENABLE_MEMORY_INDEX=1
MPS_SERVER_MEMORY_INDEX_DIR=/tmp/mps_server_artifacts/memory_index
MPS_SERVER_MEMORY_MODEL_NAME=ViT-B-32
MPS_SERVER_MEMORY_PRETRAINED=laion2b_s34b_b79k
MPS_SERVER_MEMORY_DEVICE=auto
MPS_SERVER_MEMORY_BATCH_SIZE=1
MPS_SERVER_MEMORY_SAVE_EVERY_N_UPDATES=10
MPS_SERVER_MEMORY_VISUAL_WEIGHT=0.7
MPS_SERVER_MEMORY_METADATA_WEIGHT=0.3
MPS_SERVER_ENABLE_VLM_API=1
MPS_SERVER_VLM_BIND_HOST=127.0.0.1
MPS_SERVER_VLM_PORT=19110
MPS_SERVER_VIDEO_RAG_TOP_K=3
MPS_SERVER_VIDEO_RAG_MAX_IMAGES=3
MPS_GROQ_BASE_URL=https://api.groq.com/openai/v1
MPS_GROQ_TEXT_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
MPS_GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
MPS_GROQ_TIMEOUT_S=60.0
# Set one of these locally before using the VLM API / MCP tooling:
# MPS_GROQ_API_KEY=your_groq_api_key
# GROQ_API_KEY=your_groq_api_key
MPS_SERVER_PYTHON_BIN=../.venv/bin/python
