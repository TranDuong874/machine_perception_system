# Default server runtime config for local development.
MPS_SERVER_BIND_HOST=127.0.0.1
MPS_SERVER_PORT=19100
MPS_SERVER_GRPC_WORKERS=8
MPS_SERVER_INGRESS_QUEUE_SIZE=256
MPS_SERVER_ENQUEUE_TIMEOUT_S=0.02
MPS_SERVER_LOG_EVERY_N=20
MPS_SERVER_ENABLE_GUI=1
MPS_SERVER_PREVIEW_DELAY_MS=1
MPS_SERVER_HEADLESS_PREVIEW_PATH=/tmp/mps_server_preview.jpg
MPS_SERVER_ENABLE_DEPTH=1
MPS_SERVER_DEPTH_MODEL_ID=depth-anything/DA3-BASE
MPS_SERVER_DEPTH_DEVICE=cuda
MPS_SERVER_DEPTH_PROCESS_RES=504
MPS_SERVER_PYTHON_BIN=../.venv/bin/python
